# ================================================
# LINKMIND API - ENVIRONMENT CONFIGURATION
# ================================================
# NEVER COMMIT .env FILE TO GIT!
# Get all secrets from: AWS Secrets Manager / 1Password / Vault
# This is a TEMPLATE ONLY - do not add real credentials here
# ================================================

# SERVER
PORT=3000
NODE_ENV=development
SERVER_URL=http://localhost:3000

# DATABASE
MONGODB_URI=mongodb://localhost:27017/LinkMind
MONGODB_REPLICA_SET=rs0

# JWT - GENERATE: openssl rand -hex 32
JWT_SECRET=<GENERATE_RANDOM_SECRET_32_CHARS_MIN>
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d
BCRYPT_SALT_ROUNDS=12

# SECURITY
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
SESSION_TIMEOUT=3600000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# EMAIL SERVICE - GET FROM SECRETS MANAGER
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=<GET_FROM_SECRETS_MANAGER>
SMTP_PASS=<GET_FROM_SECRETS_MANAGER>
SMTP_FROM_EMAIL=noreply@linkmind.com

# SMS SERVICE - GET FROM SECRETS MANAGER
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=<GET_FROM_SECRETS_MANAGER>
TWILIO_AUTH_TOKEN=<GET_FROM_SECRETS_MANAGER>

# CLOUDINARY IMAGE HOSTING - GET FROM SECRETS MANAGER
CLOUDINARY_CLOUD_NAME=<GET_FROM_SECRETS_MANAGER>
CLOUDINARY_API_KEY=<GET_FROM_SECRETS_MANAGER>
CLOUDINARY_API_SECRET=<GET_FROM_SECRETS_MANAGER>

# FIREBASE - GET FROM SECRETS MANAGER
FIREBASE_PROJECT_ID=<GET_FROM_SECRETS_MANAGER>
FIREBASE_PRIVATE_KEY=<GET_FROM_SECRETS_MANAGER>
FIREBASE_CLIENT_EMAIL=<GET_FROM_SECRETS_MANAGER>

# GOOGLE GENERATIVE AI (GEMINI) - GET FROM SECRETS MANAGER
GOOGLE_AI_API_KEY=<GET_FROM_SECRETS_MANAGER>

# APP CONFIGURATION
APP_NAME=LinkMind
FRONTEND_URL=http://localhost:3000
MINDO_DAILY_LIMIT_FREE=10

# LOGGING
LOG_LEVEL=debug
LOG_DIR=./logs

# OPTIONAL: HTTPS/SSL
SSL_KEY_PATH=
SSL_CERT_PATH=

# OPTIONAL: REDIS CACHE
REDIS_HOST=localhost
REDIS_PORT=6379

# OPTIONAL: MONITORING
SENTRY_DSN=