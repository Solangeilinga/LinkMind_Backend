#!/bin/sh

# Pre-commit hook for code quality checks
# Installed by Husky

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

echo "${YELLOW}🔍 Running pre-commit checks...${NC}"

# Get staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.js$')

if [ -z "$STAGED_FILES" ]; then
  echo "${GREEN}✓ No JavaScript files to check${NC}"
  exit 0
fi

echo "${YELLOW}📝 Checking files:${NC}"
echo "$STAGED_FILES"

# Run ESLint
echo "\n${YELLOW}🔨 Running ESLint...${NC}"
npm run lint -- $STAGED_FILES
if [ $? -ne 0 ]; then
  echo "${RED}✗ ESLint check failed${NC}"
  exit 1
fi

# Run tests for modified test files
TEST_FILES=$(echo "$STAGED_FILES" | grep '\.test\.js$')
if [ ! -z "$TEST_FILES" ]; then
  echo "\n${YELLOW}🧪 Running tests for modified files...${NC}"
  npm test -- $TEST_FILES --bail
  if [ $? -ne 0 ]; then
    echo "${RED}✗ Tests failed${NC}"
    exit 1
  fi
fi

echo "\n${GREEN}✓ Pre-commit checks passed!${NC}"
exit 0
