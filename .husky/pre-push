#!/bin/sh

# Pre-push hook for security checks
# Blocks push if security issues found

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

echo "${YELLOW}🛡️ Running security checks...${NC}"

# Check for exposed secrets
echo "${YELLOW}🔐 Scanning for exposed secrets...${NC}"
if git diff --cached HEAD | grep -i "password\|secret\|token" | grep -v "^[+-]\{3\}" | grep "^+"; then
  echo "${RED}✗ Potential secrets exposed in commit!${NC}"
  exit 1
fi

# Run npm audit
echo "${YELLOW}📦 Checking dependencies...${NC}"
npm audit --production
if [ $? -ne 0 ]; then
  echo "${YELLOW}⚠️  Security vulnerabilities found${NC}"
  read -p "Continue push anyway? (y/N) " -n 1 -r
  echo
  if [[ ! $REPLY =~ ^[Yy]$ ]]; then
    exit 1
  fi
fi

echo "${GREEN}✓ Security checks passed!${NC}"
exit 0
